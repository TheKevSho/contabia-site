/* ── Helpers ── */
function fmtCOP(n){return 'COP '+(Math.abs(n)||0).toLocaleString('es-CO')}
function cbar(s){const p=Math.round(s*100);const c=p>=85?'hc':p>=65?'mc':'lc';return`<div class="cbar"><div class="ctrack"><div class="cfill ${c}" style="width:${p}%"></div></div><span class="cpct">${p}%</span></div>`}
function pbadge(p){return`<span class="badge badge-${p}">${p.toUpperCase()}</span>`}
function sbadge(s){const m={pending:'Pendiente',in_review:'En revisión',approved:'Aprobado',rejected:'Rechazado',posted:'Registrado',blocked:'Bloqueado',needs_info:'Necesita info'};return`<span class="badge badge-${s}">${m[s]||s}</span>`}

/* ── Navigation ── */
const TITLES = {dashboard:'Resumen',tracker:'Seguimiento de Cierre',exceptions:'Excepciones — Marzo 2026',jes:'Comprobantes — Marzo 2026',deliverables:'Entregables',chat:'Chat con el Agente'};
function showScreen(name) {
  document.querySelectorAll('.screen').forEach(s=>{s.classList.remove('active');s.style.display='';});
  const s = document.getElementById('screen-'+name);
  if(s){s.classList.add('active'); if(name==='chat') s.style.display='flex';}
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const ni = document.getElementById('nav-'+name);
  if(ni) ni.classList.add('active');
  document.getElementById('top-title').textContent = TITLES[name]||name;
  if(name==='exceptions') renderExc('all');
  if(name==='jes') renderJEs('all');
}

/* ── Exception table ── */
function renderExc(filter) {
  const rows = filter==='all' ? EXC : filter==='pending' ? EXC.filter(e=>e.status==='pending') : EXC.filter(e=>e.priority===filter);
  document.getElementById('exc-tbody').innerHTML = rows.map(e=>`
    <tr onclick="openExcPanel('${e.id}')">
      <td><span class="pdot ${e.priority}"></span></td>
      <td><div style="font-weight:600;font-size:13px;color:var(--midnight)">${e.title}</div><div class="text-xs text-muted" style="font-family:var(--font-mono);margin-top:1px">${e.subtype}</div></td>
      <td>${pbadge(e.priority)}</td>
      <td>${sbadge(e.status)}</td>
      <td>${cbar(e.conf)}</td>
      <td class="mono" style="font-size:12px">${fmtCOP(e.amount)}</td>
      <td><div style="display:flex;gap:5px"><button class="btn btn-approve btn-xs" onclick="event.stopPropagation();alert('✓ Aprobado (demo)')">✓</button><button class="btn btn-reject btn-xs" onclick="event.stopPropagation();">✕</button></div></td>
    </tr>`).join('');
  document.querySelectorAll('#exc-filters .chip').forEach(c=>{
    c.onclick = function(){
      document.querySelectorAll('#exc-filters .chip').forEach(x=>x.classList.remove('active'));
      this.classList.add('active'); renderExc(this.dataset.f);
    };
  });
}

function openExcPanel(id) {
  const e = EXC.find(x=>x.id===id); if(!e) return;
  document.getElementById('p-badges').innerHTML = pbadge(e.priority)+sbadge(e.status);
  document.getElementById('p-title').textContent = e.title;
  document.getElementById('p-subtype').textContent = e.subtype;
  document.getElementById('p-desc').textContent = e.description;
  document.getElementById('p-rec').textContent = e.rec;
  document.getElementById('p-conf').innerHTML = cbar(e.conf);
  const rows = Object.entries(e.payload).map(([k,v])=>`<div class="flex-between" style="padding:5px 0;border-bottom:1px solid var(--light-gray)"><span class="text-xs text-muted" style="text-transform:uppercase;letter-spacing:.8px;font-weight:700">${k}</span><span class="mono text-sm">${v}</span></div>`).join('');
  document.getElementById('p-payload').innerHTML=`<div class="text-xs text-muted" style="text-transform:uppercase;letter-spacing:1px;font-weight:700;margin-bottom:6px">Datos</div><div style="background:var(--white);border:1px solid var(--light-gray);border-radius:8px;padding:2px 12px">${rows}</div>`;
  document.getElementById('exc-panel').classList.add('open');
  document.body.style.overflow='hidden';
}

/* ── JE cards ── */
function renderJEs(filter) {
  const items = filter==='all' ? JES : JES.filter(j=>j.status===filter);
  document.getElementById('je-list').innerHTML = items.map(j=>{
    const tot = (j.lines||[]).reduce((s,l)=>s+(l.debit||0),0);
    const blocked = j.status==='blocked';
    return`<div class="card" style="${blocked?'opacity:.6':''}" onclick="openJEPanel('${j.id}')" style="cursor:pointer">
      <div style="padding:14px 18px;cursor:pointer">
        <div class="flex-between">
          <div style="display:flex;align-items:center;gap:8px;flex:1;min-width:0">
            <span class="pdot ${j.priority}"></span>
            <div style="min-width:0"><div style="font-weight:600;font-size:13.5px;color:var(--midnight)">${j.title}</div><div class="text-xs text-muted" style="font-family:var(--font-mono);margin-top:1px">${j.subtype}</div></div>
          </div>
          <div style="display:flex;align-items:center;gap:8px;flex-shrink:0">
            ${cbar(j.conf)} ${sbadge(j.status)}
            <span class="mono text-sm" style="color:var(--midnight);min-width:90px;text-align:right">${fmtCOP(tot)}</span>
            ${blocked?'':`<button class="btn btn-approve btn-xs" onclick="event.stopPropagation();alert('✓ JE aprobado (demo)')">✓ Aprobar</button>`}
          </div>
        </div>
        ${blocked&&j.blocked_by?`<div class="alert alert-warning" style="margin-top:10px;margin-bottom:0;padding:7px 11px;font-size:12px">⛔ Bloqueado hasta resolver excepción: ${j.blocked_by}</div>`:''}
      </div>
    </div>`;
  }).join('');
  document.querySelectorAll('#je-tabs .tab').forEach(t=>{
    t.onclick=function(){
      document.querySelectorAll('#je-tabs .tab').forEach(x=>x.classList.remove('active'));
      this.classList.add('active'); renderJEs(this.dataset.f||'all');
    };
  });
}

function openJEPanel(id) {
  const j = JES.find(x=>x.id===id); if(!j) return;
  document.getElementById('jp-badges').innerHTML = pbadge(j.priority)+sbadge(j.status);
  document.getElementById('jp-title').textContent = j.title;
  document.getElementById('jp-subtype').textContent = j.subtype;
  document.getElementById('jp-desc').textContent = j.desc;
  document.getElementById('jp-conf').innerHTML = cbar(j.conf);
  let deb=0,cred=0;
  const lrows=(j.lines||[]).map(l=>{if(l.debit)deb+=l.debit;if(l.credit)cred+=l.credit;return`<tr><td class="mono" style="font-size:11px">${l.ac}</td><td>${l.name}</td><td>${l.desc}</td><td class="r">${l.debit?fmtCOP(l.debit):'—'}</td><td class="r">${l.credit?fmtCOP(l.credit):'—'}</td></tr>`;}).join('');
  document.getElementById('jp-lines').innerHTML=`<table class="je-table"><thead><tr><th>Cta.</th><th>Nombre</th><th>Descripción</th><th class="r">Débito</th><th class="r">Crédito</th></tr></thead><tbody>${lrows}</tbody><tfoot><tr><td colspan="3"><span class="je-ok">✓ Balanceado</span></td><td class="r">${fmtCOP(deb)}</td><td class="r">${fmtCOP(cred)}</td></tr></tfoot></table>`;
  const blk = document.getElementById('jp-block');
  if(j.blocked_by){blk.innerHTML=`<div class="alert alert-warning" style="margin-bottom:14px">⛔ Bloqueado hasta resolver: ${j.blocked_by}</div>`;document.getElementById('jp-ftr').style.display='none';}
  else{blk.innerHTML='';document.getElementById('jp-ftr').style.display='flex';}
  document.getElementById('je-panel').classList.add('open');
  document.body.style.overflow='hidden';
}

function closePanel(id){
  document.getElementById(id).classList.remove('open');
  document.body.style.overflow='';
}

/* ── Chat ── */
function fillChat(btn){document.getElementById('chat-inp').value=btn.textContent;document.getElementById('chat-inp').focus();}
function sendChat(){
  const inp=document.getElementById('chat-inp'),txt=inp.value.trim();
  if(!txt)return;
  const msgs=document.getElementById('chat-msgs');
  msgs.innerHTML+=`<div style="align-self:flex-end"><div class="bubble user">${txt}</div></div>`;
  inp.value='';
  setTimeout(()=>{
    msgs.innerHTML+=`<div><div class="bubble agent"><div class="bmeta">Agente ContabIA</div>Procesando su consulta sobre los libros de Cantamar Beach Hostel… En producción, el agente respondería con datos reales de Alegra y LobbyPMS.</div></div>`;
    msgs.scrollTop=msgs.scrollHeight;
  },700);
  msgs.scrollTop=msgs.scrollHeight;
}

/* Init */
renderExc('all');
renderJEs('all');
</script>

