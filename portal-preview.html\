<!DOCTYPE html>

<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ContabIA Portal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Source+Sans+3:wght@300;400;600;700&family=Source+Code+Pro:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root {
  --midnight:#1B2A4A; --ocean:#2D5F8A; --sky:#4A9FD4; --terracotta:#D4704A;
  --sand:#F5E6D0; --cream:#FFF8F0; --white:#FFFFFF; --charcoal:#2C2C2C;
  --warm-gray:#8B8178; --light-gray:#E8E2DB;
  --sidebar-w:240px; --radius:8px; --radius-lg:12px;
  --shadow-sm:0 1px 3px rgba(27,42,74,.08); --shadow-md:0 4px 12px rgba(27,42,74,.12); --shadow-lg:0 8px 24px rgba(27,42,74,.16);
  --font-display:'DM Serif Display',Georgia,serif; --font-body:'Source Sans 3',system-ui,sans-serif; --font-mono:'Source Code Pro',monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px}
body{font-family:var(--font-body);background:var(--cream);color:var(--charcoal);line-height:1.5;-webkit-font-smoothing:antialiased;overflow:hidden;height:100vh}
a{color:var(--ocean);text-decoration:none} a:hover{color:var(--sky)}
button{font-family:var(--font-body);cursor:pointer;border:none}
input,select,textarea{font-family:var(--font-body)}
.portal-shell{display:flex;height:100vh;overflow:hidden}
.sidebar{width:var(--sidebar-w);background:var(--midnight);display:flex;flex-direction:column;height:100vh;z-index:100;overflow-y:auto;flex-shrink:0}
.sidebar-logo{padding:24px 20px 20px;border-bottom:1px solid rgba(255,255,255,.08)}
.wordmark{font-family:var(--font-display);font-size:22px;color:#FFF8F0;letter-spacing:-.3px}
.wordmark span{color:var(--terracotta)}
.tagline{font-size:11px;color:rgba(255,248,240,.45);margin-top:4px;letter-spacing:.3px}
.sidebar-client{padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.08)}
.client-name{font-size:13px;font-weight:600;color:var(--cream);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.period-badge{display:inline-block;margin-top:5px;font-size:11px;background:rgba(212,112,74,.2);color:#F0A07A;border:1px solid rgba(212,112,74,.3);border-radius:4px;padding:2px 7px;font-family:var(--font-mono)}
.sidebar-nav{flex:1;padding:12px 0}
.nav-section-label{font-size:10px;font-weight:700;color:rgba(255,248,240,.3);letter-spacing:1.5px;text-transform:uppercase;padding:12px 20px 4px}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 20px;color:rgba(255,248,240,.65);font-size:14px;transition:all .15s;position:relative;cursor:pointer;text-decoration:none}
.nav-item:hover{background:rgba(255,255,255,.06);color:var(--cream)}
.nav-item.active{background:rgba(212,112,74,.15);color:var(--cream);font-weight:600}
.nav-item.active::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--terracotta);border-radius:0 2px 2px 0}
.nav-icon{width:18px;height:18px;flex-shrink:0;opacity:.7}
.nav-item.active .nav-icon{opacity:1}
.nav-badge{margin-left:auto;font-size:11px;font-weight:700;background:var(--terracotta);color:white;border-radius:10px;padding:1px 7px;min-width:20px;text-align:center}
.nav-badge.critical{background:#C0392B}
.sidebar-footer{padding:16px 20px;border-top:1px solid rgba(255,255,255,.08);font-size:12px;color:rgba(255,248,240,.4)}
.sidebar-footer .user-name{color:rgba(255,248,240,.7);font-weight:600}
.main-content{flex:1;display:flex;flex-direction:column;min-height:100vh;overflow:hidden}
.top-bar{background:var(--white);border-bottom:1px solid var(--light-gray);padding:0 28px;height:60px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;z-index:50}
.top-bar-title{font-family:var(--font-display);font-size:20px;color:var(--midnight)}
.top-bar-actions{display:flex;align-items:center;gap:10px}
.page-content{padding:24px 28px;flex:1;overflow-y:auto}
.screen{display:none}
.screen.active{display:block}

/* Buttons */
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:var(–radius);font-size:14px;font-weight:600;transition:all .15s;cursor:pointer;border:none}
.btn-primary{background:var(–terracotta);color:white} .btn-primary:hover{background:#C05E3A}
.btn-secondary{background:transparent;color:var(–ocean);border:1.5px solid var(–ocean)} .btn-secondary:hover{background:var(–ocean);color:white}
.btn-ghost{background:transparent;color:var(–warm-gray);border:1.5px solid var(–light-gray)} .btn-ghost:hover{border-color:var(–ocean);color:var(–ocean)}
.btn-approve{background:#1E7E34;color:white;font-size:13px;padding:6px 14px} .btn-approve:hover{background:#165A25}
.btn-reject{background:transparent;color:#C0392B;border:1.5px solid #C0392B;font-size:13px;padding:6px 14px} .btn-reject:hover{background:#C0392B;color:white}
.btn-sm{padding:5px 12px;font-size:13px} .btn-xs{padding:3px 9px;font-size:12px}

/* Cards */
.card{background:var(–white);border:1px solid var(–light-gray);border-radius:var(–radius-lg);box-shadow:var(–shadow-sm)}
.card-header{padding:16px 20px 12px;border-bottom:1px solid var(–light-gray);display:flex;align-items:center;justify-content:space-between}
.card-title{font-family:var(–font-display);font-size:17px;color:var(–midnight)}
.card-body{padding:20px}

/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
.kpi-tile{background:var(–white);border:1px solid var(–light-gray);border-radius:var(–radius-lg);padding:16px 18px;box-shadow:var(–shadow-sm)}
.kpi-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(–warm-gray);margin-bottom:6px}
.kpi-value{font-family:var(–font-mono);font-size:20px;font-weight:700;color:var(–midnight)}
.kpi-sub{font-size:11px;color:var(–warm-gray);margin-top:3px}
.kpi-tile.ta{border-left:4px solid var(–terracotta)}
.kpi-tile.oc{border-left:4px solid var(–ocean)}
.kpi-tile.gr{border-left:4px solid #1E7E34}
.kpi-tile.re{border-left:4px solid #C0392B}

/* Badges */
.badge{display:inline-flex;align-items:center;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;padding:2px 8px;border-radius:20px}
.badge-critical{background:#FDECEA;color:#C0392B} .badge-high{background:#FFF3CD;color:#856404}
.badge-medium{background:#E3F0FF;color:#1A5276} .badge-low{background:#E8F8F5;color:#1A7A4A}
.badge-approved{background:#D4EDDA;color:#155724} .badge-pending{background:#FFF3CD;color:#856404}
.badge-posted{background:#D4EDDA;color:#155724} .badge-rejected{background:#FDECEA;color:#C0392B}
.badge-blocked{background:#F0F0F0;color:#666} .badge-closed{background:#D4EDDA;color:#155724}
.badge-progress{background:#E3F0FF;color:var(–ocean)} .badge-in_review{background:#E3F0FF;color:#1A5276}
.badge-needs_info{background:#FFF3CD;color:#856404}

/* Priority dot */
.pdot{width:8px;height:8px;border-radius:50%;display:inline-block;flex-shrink:0}
.pdot.critical{background:#C0392B} .pdot.high{background:#E67E22} .pdot.medium{background:var(–ocean)} .pdot.low{background:#1A7A4A}

/* Tables */
.data-table{width:100%;border-collapse:collapse;font-size:13px}
.data-table th{padding:9px 12px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(–warm-gray);border-bottom:2px solid var(–light-gray);text-align:left;white-space:nowrap}
.data-table td{padding:10px 12px;border-bottom:1px solid var(–light-gray);vertical-align:middle}
.data-table tbody tr:hover{background:rgba(245,230,208,.3);cursor:pointer}
.data-table tbody tr:last-child td{border-bottom:none}

/* Confidence bar */
.cbar{display:flex;align-items:center;gap:6px;min-width:72px}
.ctrack{flex:1;height:4px;background:var(–light-gray);border-radius:2px;overflow:hidden}
.cfill{height:100%;border-radius:2px}
.cfill.hc{background:#1E7E34} .cfill.mc{background:#E67E22} .cfill.lc{background:#C0392B}
.cpct{font-family:var(–font-mono);font-size:10px;color:var(–warm-gray);min-width:26px}

/* Alerts */
.alert{padding:10px 14px;border-radius:var(–radius);font-size:13px;display:flex;align-items:flex-start;gap:10px;margin-bottom:14px}
.alert-critical{background:#FDECEA;border-left:4px solid #C0392B;color:#7B241C}
.alert-warning{background:#FFF8E1;border-left:4px solid #E67E22;color:#7D4E00}
.alert-info{background:#E3F2FF;border-left:4px solid var(–ocean);color:#1A4A6A}

/* Filter chips */
.filter-row{display:flex;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap}
.chip{padding:4px 11px;border-radius:20px;font-size:11px;font-weight:600;border:1.5px solid var(–light-gray);background:var(–white);color:var(–warm-gray);cursor:pointer;transition:all .15s}
.chip:hover,.chip.active{border-color:var(–ocean);background:var(–ocean);color:white}
.chip.crit.active{background:#C0392B;border-color:#C0392B}

/* Tabs */
.tabs{display:flex;border-bottom:2px solid var(–light-gray);margin-bottom:16px}
.tab{padding:9px 16px;font-size:13px;font-weight:600;color:var(–warm-gray);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .15s}
.tab:hover{color:var(–ocean)} .tab.active{color:var(–terracotta);border-bottom-color:var(–terracotta)}

/* Month tracker */
.month-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.month-card{background:var(–white);border:1px solid var(–light-gray);border-radius:var(–radius-lg);overflow:hidden;box-shadow:var(–shadow-sm)}
.month-card-header{padding:12px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(–light-gray)}
.month-name{font-family:var(–font-display);font-size:15px;color:var(–midnight)}
.month-card-modules{padding:10px 16px}
.mrow{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid rgba(232,226,219,.5)}
.mrow:last-child{border-bottom:none}
.micon{width:24px;height:24px;border-radius:5px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:11px}
.micon.ok{background:#E8F8F5;color:#1A7A4A} .micon.warn{background:#FFF3CD;color:#856404} .micon.pend{background:#F0F0F0;color:#999}
.mlabel{font-size:12px;color:var(–charcoal);flex:1} .mnote{font-size:10px;color:var(–warm-gray)}

/* JE table */
.je-table{width:100%;border-collapse:collapse;font-size:12px;margin:10px 0}
.je-table th{background:var(–sand);padding:7px 10px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(–midnight);text-align:left}
.je-table th.r{text-align:right} .je-table td{padding:7px 10px;border-bottom:1px solid var(–light-gray)}
.je-table td.r{text-align:right;font-family:var(–font-mono);font-size:12px}
.je-table tfoot td{font-weight:700;border-top:2px solid var(–midnight);padding-top:8px}
.je-ok{color:#1E7E34;font-size:11px}

/* Deliverables */
.drow{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(–light-gray)}
.drow:last-child{border-bottom:none}
.dicon{width:34px;height:34px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.dicon.xl{background:#E8F5E9;color:#1E7E34} .dicon.pdf{background:#FDECEA;color:#C0392B}
.dname{font-size:13px;font-weight:600;color:var(–midnight)} .dmeta{font-size:11px;color:var(–warm-gray);margin-top:1px}

/* Chat */
.chat-wrap{display:flex;flex-direction:column;height:calc(100vh - 130px)}
.chat-msgs{flex:1;overflow-y:auto;padding:16px 0;display:flex;flex-direction:column;gap:12px}
.bubble{max-width:68%;padding:10px 14px;border-radius:var(–radius-lg);font-size:13.5px;line-height:1.6}
.bubble.agent{background:var(–midnight);color:var(–cream);border-bottom-left-radius:3px;align-self:flex-start}
.bubble.user{background:var(–sand);color:var(–charcoal);border-bottom-right-radius:3px;align-self:flex-end}
.bmeta{font-size:10px;opacity:.55;margin-bottom:4px}
.chat-input-row{display:flex;gap:8px;padding-top:12px;border-top:1px solid var(–light-gray);flex-shrink:0}
.chat-inp{flex:1;padding:10px 14px;border:1.5px solid var(–light-gray);border-radius:24px;font-size:13px;outline:none}
.chat-inp:focus{border-color:var(–ocean)}
.chat-send{width:40px;height:40px;border-radius:50%;background:var(–terracotta);color:white;display:flex;align-items:center;justify-content:center;flex-shrink:0;cursor:pointer;border:none}

/* Slide panel */
.overlay{position:fixed;inset:0;background:rgba(27,42,74,.45);z-index:300;display:none;align-items:stretch;justify-content:flex-end}
.overlay.open{display:flex}
.panel{background:var(–white);width:min(560px,90vw);height:100vh;overflow-y:auto;display:flex;flex-direction:column;box-shadow:-8px 0 32px rgba(27,42,74,.2)}
.panel-hdr{padding:18px 22px;border-bottom:1px solid var(–light-gray);display:flex;align-items:flex-start;gap:10px;position:sticky;top:0;background:var(–white);z-index:10}
.panel-body{padding:22px;flex:1}
.panel-ftr{padding:14px 22px;border-top:1px solid var(–light-gray);display:flex;gap:8px;justify-content:flex-end;position:sticky;bottom:0;background:var(–white)}
.close-btn{margin-left:auto;background:none;border:none;font-size:19px;color:var(–warm-gray);cursor:pointer;padding:0 0 0 8px}

/* Helpers */
.mono{font-family:var(–font-mono)}
.flex-between{display:flex;align-items:center;justify-content:space-between}
.flex-center{display:flex;align-items:center}
.gap-8{gap:8px} .gap-10{gap:10px} .gap-12{gap:12px}
.mt-16{margin-top:16px} .mt-20{margin-top:20px}
.text-sm{font-size:13px} .text-xs{font-size:11px} .text-muted{color:var(–warm-gray)}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.negative{color:#C0392B} .positive{color:#1E7E34}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-thumb{background:var(–light-gray);border-radius:3px}

/* Section header */
.sec-hdr{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:14px}
.sec-title{font-family:var(–font-display);font-size:19px;color:var(–midnight)}
.sec-sub{font-size:12px;color:var(–warm-gray);margin-top:2px}
</style>

</head>
<body>
<div class="portal-shell">

<!-- SIDEBAR -->

<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="wordmark">Contab<span>IA</span></div>
    <div class="tagline">Su agente cierra sus libros.</div>
  </div>
  <div class="sidebar-client">
    <div class="client-name">Cantamar Beach Hostel</div>
    <span class="period-badge">Marzo 2026</span>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-section-label">Principal</div>
    <a class="nav-item active" id="nav-dashboard" onclick="showScreen('dashboard')">
      <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      Resumen
    </a>
    <a class="nav-item" id="nav-tracker" onclick="showScreen('tracker')">
      <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
      Seguimiento de Cierre
    </a>
    <div class="nav-section-label">Revisión</div>
    <a class="nav-item" id="nav-exceptions" onclick="showScreen('exceptions')">
      <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      Excepciones
      <span class="nav-badge critical">7</span>
    </a>
    <a class="nav-item" id="nav-jes" onclick="showScreen('jes')">
      <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      Comprobantes (JEs)
      <span class="nav-badge">5</span>
    </a>
    <div class="nav-section-label">Informes</div>
    <a class="nav-item" id="nav-deliverables" onclick="showScreen('deliverables')">
      <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
      Entregables
    </a>
    <div class="nav-section-label">Agente</div>
    <a class="nav-item" id="nav-chat" onclick="showScreen('chat')">
      <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      Chat con el Agente
    </a>
  </nav>
  <div class="sidebar-footer">
    <div class="user-name">Kevin Carey</div>
    <div>Propietario</div>
  </div>
</aside>

<!-- MAIN -->

<div class="main-content">

  <!-- TOP BAR -->

  <div class="top-bar" id="top-bar">
    <div class="top-bar-title" id="top-title">Resumen</div>
    <div class="top-bar-actions" id="top-actions">
      <span class="text-sm text-muted">Procesado hace 2 horas</span>
      <button class="btn btn-ghost btn-sm">↻ Actualizar</button>
      <button class="btn btn-primary btn-sm" onclick="showScreen('exceptions')">Revisar pendientes</button>
    </div>
  </div>

  <!-- ══════════════ DASHBOARD ══════════════ -->

  <div class="page-content screen active" id="screen-dashboard">
    <div class="alert alert-warning">
      <span>⚠️</span>
      <div><strong>Cierre de Marzo 2026 en progreso.</strong> Hay 2 excepciones críticas y 5 comprobantes pendientes. <a onclick="showScreen('exceptions')" style="font-weight:600;cursor:pointer;">Ver excepciones →</a></div>
    </div>
    <div class="kpi-grid">
      <div class="kpi-tile ta"><div class="kpi-label">Excepciones abiertas</div><div class="kpi-value">14</div><div class="kpi-sub">2 críticas · 5 altas · 4 medias · 3 bajas</div></div>
      <div class="kpi-tile oc"><div class="kpi-label">Comprobantes (JEs)</div><div class="kpi-value">18</div><div class="kpi-sub">7 pendientes · 8 aprobados · 3 registrados</div></div>
      <div class="kpi-tile gr"><div class="kpi-label">Recuperación tributaria</div><div class="kpi-value">1.248.500</div><div class="kpi-sub">COP estimado — docs soporte + retefuente</div></div>
      <div class="kpi-tile re"><div class="kpi-label">Estado del cierre</div><div class="kpi-value" style="font-size:16px;color:#C0392B;">No listo</div><div class="kpi-sub">Bloqueos: EXC-001, EXC-004</div></div>
    </div>
    <div class="grid-2" style="gap:16px">
      <div class="card">
        <div class="card-header"><div class="card-title">Progreso del cierre</div></div>
        <table class="data-table">
          <tbody>
            <tr><td><span style="font-size:16px">✅</span> <strong style="font-size:13px">Ingesta bancaria</strong> <span class="text-xs text-muted">— Bancolombia OK</span></td><td style="text-align:right"><span class="badge badge-approved">Completo</span></td></tr>
